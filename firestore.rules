rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function matchKickoffAt(tournamentId, matchId) {
      return get(/databases/$(database)/documents/seasons/$(tournamentId)/matches/$(matchId)).data.kickoffAt;
    }

    // --- legacy picks_status / picks_detail helpers ---

    function clientLockedAtIsNull() {
      return request.resource.data.lockedAt == null;
    }

    function isNotLocked() {
      return resource == null || resource.data.lockedAt == null;
    }

    function isBeforeKickoff() {
      let kickoff = resource == null
        ? request.resource.data.kickoffAt
        : resource.data.kickoffAt;
      return request.time < kickoff;
    }

    // --- predictions helpers ---

    function predictionKeysAreValid() {
      return request.resource.data.keys().hasOnly([
        'userId',
        'matchId',
        'tournamentId',
        'winner',
        'margin',
        'kickoffAt',
        'isComplete',
        'isLocked',
        'lockedAt',
        'createdAt',
        'updatedAt'
      ]);
    }

    function predictionCreatedAtIsImmutable() {
      return resource == null || request.resource.data.createdAt == resource.data.createdAt;
    }

    function predictionIdentityIsImmutable() {
      return resource == null || (
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.matchId == resource.data.matchId &&
        request.resource.data.tournamentId == resource.data.tournamentId
      );
    }

    function predictionClientLockStateIsValid() {
      return request.resource.data.lockedAt == null && request.resource.data.isLocked == false;
    }

    function predictionMarginIsValid() {
      return request.resource.data.margin == null || (
        request.resource.data.margin >= 1 &&
        request.resource.data.margin <= 99
      );
    }

    function predictionCompletenessIsValid() {
      return request.resource.data.isComplete == (
        request.resource.data.winner != null && request.resource.data.margin != null
      );
    }

    function predictionNotLocked() {
      return resource == null || (
        resource.data.lockedAt == null &&
        resource.data.isLocked != true
      );
    }

    function predictionBeforeKickoff() {
      return request.time < matchKickoffAt(
        request.resource.data.tournamentId,
        request.resource.data.matchId
      );
    }

    // --- user profile helpers ---

    function userProfileKeysAreValid() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'email',
        'displayName',
        'photoURL',
        'countryCode',
        'hemisphere',
        'isPundit',
        'createdAt',
        'updatedAt',
        'lastSignInAt'
      ]);
    }

    function userProfileUidIsValid(userId) {
      return request.resource.data.uid == userId && (
        resource == null ||
        resource.data.uid == null ||
        request.resource.data.uid == resource.data.uid
      );
    }

    function userProfileCreatedAtIsImmutable() {
      return resource == null ||
        resource.data.createdAt == null ||
        request.resource.data.createdAt == resource.data.createdAt;
    }

    function userProfilePunditIsUnchanged() {
      return resource == null
        ? request.resource.data.isPundit == false
        : resource.data.isPundit == null
          ? request.resource.data.isPundit == false
          : request.resource.data.isPundit == resource.data.isPundit;
    }

    function userProfileCountryCodeIsValid() {
      return !request.resource.data.keys().hasAny(['countryCode']) ||
      request.resource.data.countryCode == null || (
        request.resource.data.countryCode is string &&
        request.resource.data.countryCode.matches('^[A-Z]{2}$')
      );
    }

    function userProfileHemisphereIsValid() {
      return !request.resource.data.keys().hasAny(['hemisphere']) ||
      request.resource.data.hemisphere == null || (
        request.resource.data.hemisphere in ['north', 'south']
      );
    }


    // ---- Seasons / Matches (global fixtures) ----
    // Readable by all; writable only by Admin SDK (seed script runs client-side
    // in dev, so we keep open for now — full restriction in M5).
    match /seasons/{document=**} {
      allow read: if true;
      allow write: if true; // Dev/seed only — tighten in M5
    }

    // ---- Pools ----
    // Full membership rules come in M5; keep open for creation and joining.
    match /pools/{poolId} {
      allow read, write: if true;
    }

    match /pools/{poolId}/members/{userId} {
      allow read, write: if true;
    }

    // ---- Users ----
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if
        isSignedIn() &&
        request.auth.uid == userId &&
        userProfileKeysAreValid() &&
        userProfileUidIsValid(userId) &&
        userProfileCreatedAtIsImmutable() &&
        userProfilePunditIsUnchanged() &&
        userProfileCountryCodeIsValid() &&
        userProfileHemisphereIsValid();
    }

    // ---- predictions ----
    // Universal per-user, per-match predictions.
    // Client can only edit their own, before kickoff, while unlocked.
    match /predictions/{docId} {
      allow read: if isSignedIn() && (
        resource == null ||
        resource.data.userId == request.auth.uid ||
        request.time >= matchKickoffAt(resource.data.tournamentId, resource.data.matchId)
      );

      allow write: if
        isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        predictionKeysAreValid() &&
        predictionCreatedAtIsImmutable() &&
        predictionIdentityIsImmutable() &&
        predictionClientLockStateIsValid() &&
        predictionMarginIsValid() &&
        predictionCompletenessIsValid() &&
        predictionNotLocked() &&
        predictionBeforeKickoff();
    }

    // ---- picks_status ----
    // Temporary compatibility mirror during migration.
    match /pools/{poolId}/picks_status/{docId} {
      allow read: if true;
      allow write: if
        isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        clientLockedAtIsNull() &&
        isNotLocked() &&
        isBeforeKickoff();
    }

    // ---- picks_detail ----
    // Temporary compatibility mirror during migration.
    match /pools/{poolId}/picks_detail/{docId} {
      allow read: if true;
      allow write: if
        isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        isNotLocked() &&
        isBeforeKickoff() &&
        request.resource.data.pickedMargin >= 1 &&
        request.resource.data.pickedMargin <= 99;
    }

    // ---- Server-only collections (leaderboard, scoring) ----
    match /pools/{poolId}/leaderboard/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /pools/{poolId}/rounds/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /pools/{poolId}/scoring_runs/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /user_tournament_stats/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /scoring_runs/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
