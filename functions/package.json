{
  "name": "functions",
  "version": "1.0.0",
  "description": "Cloud Functions for Six Nations Predictor",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "jest --verbose"
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "@google-cloud/tasks": "^5.0.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.4.0"
  },
  "private": true
}
